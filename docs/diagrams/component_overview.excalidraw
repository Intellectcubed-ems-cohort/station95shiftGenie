      "seed": 75595619,
      "version": 312,
      "versionNonce": 232481331,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1774891563696,
      "link": null,
      "locked": false,
      "text": "Field processors are mapped in the file Mappings.  They attempt to \nparse the field into the required components.\nCall LLM if fieldProcessor cannot process.\n\nShort circuit - if LLM is called for more than 10% of the fields, stop\ncalling LLM - this indicates we need a new type of field processor.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Field processors are mapped in the file Mappings.  They attempt to \nparse the field into the required components.\nCall LLM if fieldProcessor cannot process.\n\nShort circuit - if LLM is called for more than 10% of the fields, stop\ncalling LLM - this indicates we need a new type of field processor.",
      "autoResize": true,
      "lineHeight": 1.25
    },
